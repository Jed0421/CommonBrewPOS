@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CommonBrew POS – Sign In</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="~/css/app.css" rel="stylesheet" />
</head>
<body class="login-body">
    <div class="login-bg">
        <div class="login-bg-overlay"></div>
        <!-- Floating coffee bean decorations -->
        <div class="bean b1">☕</div>
        <div class="bean b2">🫘</div>
        <div class="bean b3">☕</div>
        <div class="bean b4">🫘</div>
        <div class="bean b5">☕</div>
    </div>

    <div class="login-card">
        <div class="login-logo">
            <span class="login-logo-icon">☕</span>
            <span class="login-logo-text">COMMONBREW</span>
        </div>
        <h2 class="login-title">Welcome Back</h2>
        <p class="login-subtitle">Sign in to continue to CommonBrew POS</p>

        @if (ViewBag.Error != null)
        {
            <div class="login-error">@ViewBag.Error</div>
        }

        <form asp-controller="Auth" asp-action="Login" method="post" class="login-form">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">User Role</label>
                <div class="select-wrap">
                    <span class="select-icon">👤</span>
                    <select name="role" class="form-select" required>
                        <option value="Administrator">Administrator</option>
                        <option value="Cashier">Cashier</option>
                    </select>
                    <span class="select-arrow">▾</span>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Username</label>
                <div class="input-wrap">
                    <span class="input-icon">👤</span>
                    <input type="text" name="username" class="form-input"
                           placeholder="Enter your username" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Password</label>
                <div class="input-wrap">
                    <span class="input-icon">🔒</span>
                    <input type="password" name="password" class="form-input"
                           placeholder="Enter your password" id="pwdInput" required />
                    <button type="button" class="pwd-toggle" onclick="togglePwd()">👁</button>
                </div>
            </div>

            <button type="submit" class="login-btn">Sign In</button>
        </form>
    </div>

    <script>
        function togglePwd() {
            const inp = document.getElementById('pwdInput');
            inp.type = inp.type === 'password' ? 'text' : 'password';
        }
    </script>
</body>
</html>
