@model List<CommonBrewPOS.Models.InventoryItem>
@{
    ViewData["Title"] = "Inventory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Inventory Management</h1>
        <p class="page-subtitle">Monitor and manage ingredients and stocks.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn-primary">+ Add Stock Item</a>
    </div>
</div>

<div class="table-card">
    <table class="data-table">
        <thead>
            <tr>
                <th>Item Name</th>
                <th>Current Stock</th>
                <th>Critical Level</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="font-medium">@item.Name</td>
                    <td>
                        <strong>@item.CurrentStock</strong>
                        <span class="unit-label">@item.Unit</span>
                    </td>
                    <td>
                        @item.CriticalLevel
                        <span class="unit-label">@item.Unit</span>
                    </td>
                    <td>
                        <div class="stock-bar-wrap">
                            <div class="stock-bar">
                                <div class="stock-bar-fill @(item.IsLowStock ? "low" : "good")"
                                     style="width: @(Math.Min((double)item.StockPercent, 100))%"></div>
                            </div>
                            <span class="status-badge @(item.IsLowStock ? "badge-red" : "badge-green")">
                                @item.StatusLabel
                            </span>
                        </div>
                    </td>
                    <td>
                        <div class="action-row">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="link-blue">Edit</a>
                            <button class="link-orange"
                                    onclick="showAddStock('@item.Id', '@item.Name', '@item.Unit')">
                                + Add Stock
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Add Stock Modal -->
<div class="modal-overlay" id="addStockModal" style="display:none">
    <div class="modal-card">
        <h3 class="modal-title">Add Stock</h3>
        <p id="addStockLabel" class="modal-subtitle"></p>
        <div class="form-group">
            <label class="form-label">Quantity to Add</label>
            <input type="number" id="stockQty" class="form-input" min="0.01" step="0.01"
                   placeholder="Enter quantity" />
        </div>
        <div class="form-group">
            <label class="form-label">Note (optional)</label>
            <input type="text" id="stockNote" class="form-input" placeholder="e.g. Delivery from supplier" />
        </div>
        <div class="modal-actions">
            <button class="btn-outline" onclick="closeAddStock()">Cancel</button>
            <button class="btn-primary" onclick="submitAddStock()">Add Stock</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let currentItemId = '';
    function showAddStock(id, name, unit) {
        currentItemId = id;
        document.getElementById('addStockLabel').textContent = `${name} (${unit})`;
        document.getElementById('stockQty').value = '';
        document.getElementById('stockNote').value = '';
        document.getElementById('addStockModal').style.display = 'flex';
    }
    function closeAddStock() {
        document.getElementById('addStockModal').style.display = 'none';
    }
    async function submitAddStock() {
        const qty = parseFloat(document.getElementById('stockQty').value);
        const note = document.getElementById('stockNote').value;
        if (!qty || qty <= 0) { alert('Enter a valid quantity.'); return; }
        const res = await fetch('/Inventory/AddStockAjax', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ itemId: currentItemId, quantity: qty, note })
        });
        const data = await res.json();
        if (data.success) { location.reload(); }
        else { alert('Error adding stock.'); }
    }
</script>
}
