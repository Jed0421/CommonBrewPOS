@model List<CommonBrewPOS.Models.Product>
@{
    ViewData["Title"] = "Products";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Menu Manager</h1>
        <p class="page-subtitle">Manage your products and recipes</p>
    </div>
    <a asp-action="Create" class="btn-primary">+ Add New Item</a>
</div>

<div class="products-grid">
    @foreach (var product in Model)
    {
        <div class="product-mgmt-card">
            @if (!string.IsNullOrEmpty(product.ImageUrl))
            {
                <div class="product-mgmt-img">
                    <img src="@product.ImageUrl" alt="@product.Name" />
                    @if (!string.IsNullOrEmpty(product.CategoryName))
                    {
                        <span class="cat-tag">@product.CategoryName</span>
                    }
                </div>
            }
            else
            {
                <div class="product-mgmt-img placeholder">
                    <span>☕</span>
                    @if (!string.IsNullOrEmpty(product.CategoryName))
                    {
                        <span class="cat-tag">@product.CategoryName</span>
                    }
                </div>
            }
            <div class="product-mgmt-body">
                <div class="product-mgmt-header">
                    <h4 class="product-mgmt-name">@product.Name</h4>
                    <span class="product-mgmt-price">₱@product.Price.ToString("N2")</span>
                </div>
                @if (product.Recipes.Any())
                {
                    <div class="recipe-section">
                        <p class="recipe-label">📋 RECIPE</p>
                        @foreach (var r in product.Recipes)
                        {
                            <div class="recipe-row">
                                <span>@r.InventoryItemName</span>
                                <span class="recipe-qty">@r.Quantity @r.Unit</span>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="product-mgmt-actions">
                <a asp-action="Edit" asp-route-id="@product.Id" class="btn-edit">✏ Edit</a>
                <form asp-action="Delete" method="post" style="display:inline"
                      onsubmit="return confirm('Delete @product.Name?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@product.Id" />
                    <button type="submit" class="btn-delete">🗑</button>
                </form>
            </div>
        </div>
    }
</div>
